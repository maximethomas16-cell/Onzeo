<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

  <uses-permission android:name="android.permission.INTERNET" />
  <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

  <application
    android:allowBackup="true"
    android:icon="@mipmap/ic_launcher"
    android:label="@string/app_name"
    android:roundIcon="@mipmap/ic_launcher_round"
    android:supportsRtl="true"
    android:theme="@style/Theme.FcRegnyWidget"
    android:usesCleartextTraffic="true">

    <activity
      android:name=".MainActivity"
      android:exported="true"
      android:label="@string/app_name"
      android:launchMode="singleTop">
      <intent-filter>
        <action android:name="android.intent.action.MAIN" />
        <category android:name="android.intent.category.LAUNCHER" />
      </intent-filter>
      <intent-filter>
        <action android:name="android.appwidget.action.APPWIDGET_CONFIGURE" />
      </intent-filter>
    </activity>

    <activity
      android:name=".ClubSelectionWebActivity"
      android:exported="false"
      android:label="@string/selector_title" />

    <activity
      android:name=".AdminWebActivity"
      android:exported="false"
      android:label="@string/admin_title" />

    <receiver
      android:name=".FcRegnyWidgetProvider"
      android:exported="false"
      android:label="@string/widget_label">
      <intent-filter>
        <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
        <action android:name="android.intent.action.BOOT_COMPLETED" />
        <action android:name="fr.fcregny.widget.action.REFRESH" />
      </intent-filter>

      <meta-data
        android:name="android.appwidget.provider"
        android:resource="@xml/fc_regny_widget_info" />
    </receiver>
  </application>

</manifest>
