<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:id="@+id/widgetRoot"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="@drawable/bg_widget"
  android:orientation="vertical"
  android:padding="10dp">

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <ImageView
      android:id="@+id/widgetClubBadge"
      android:layout_width="26dp"
      android:layout_height="26dp"
      android:contentDescription="@string/widget_label"
      android:src="@drawable/ic_club_badge" />

    <LinearLayout
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_marginStart="10dp"
      android:layout_weight="1"
      android:orientation="vertical">

      <TextView
        android:id="@+id/widgetClubName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="@string/widget_label"
        android:textColor="@android:color/white"
        android:textSize="15sp"
        android:textStyle="bold" />

      <TextView
        android:id="@+id/widgetSeasonTeam"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="@string/widget_subtitle"
        android:textColor="#CCFFFFFF"
        android:textSize="11sp" />
    </LinearLayout>

    <TextView
      android:id="@+id/widgetAdminAction"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:background="@drawable/bg_widget_action"
      android:paddingLeft="8dp"
      android:paddingTop="5dp"
      android:paddingRight="8dp"
      android:paddingBottom="5dp"
      android:text="@string/widget_admin"
      android:textColor="@android:color/white"
      android:textSize="10sp"
      android:textStyle="bold" />

    <TextView
      android:id="@+id/widgetRefreshAction"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginStart="6dp"
      android:background="@drawable/bg_widget_action"
      android:paddingLeft="8dp"
      android:paddingTop="5dp"
      android:paddingRight="8dp"
      android:paddingBottom="5dp"
      android:text="@string/widget_refresh"
      android:textColor="@android:color/white"
      android:textSize="10sp"
      android:textStyle="bold" />
  </LinearLayout>

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp"
    android:background="@drawable/bg_widget_section"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="10dp">

    <TextView
      android:id="@+id/largeStandingRank"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:text="NC"
      android:textColor="@android:color/white"
      android:textSize="24sp"
      android:textStyle="bold" />

    <LinearLayout
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_marginStart="12dp"
      android:layout_weight="1"
      android:orientation="vertical">

      <TextView
        android:id="@+id/largeStandingDivision"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/widget_standing_label"
        android:textColor="#FFF3D7"
        android:textSize="11sp"
        android:textStyle="bold" />

      <TextView
        android:id="@+id/largeStandingTeam"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@android:color/white"
        android:textSize="14sp"
        android:textStyle="bold" />

      <TextView
        android:id="@+id/largeStandingMeta"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="#CCFFFFFF"
        android:textSize="11sp" />
    </LinearLayout>
  </LinearLayout>

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp"
    android:orientation="horizontal">

    <LinearLayout
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_marginEnd="4dp"
      android:layout_weight="1"
      android:background="@drawable/bg_widget_section"
      android:orientation="vertical"
      android:padding="10dp">

      <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/widget_last_match"
        android:textColor="#FFF3D7"
        android:textSize="10sp"
        android:textStyle="bold" />

      <TextView
        android:id="@+id/largeLastMatchDate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="#CCFFFFFF"
        android:textSize="11sp" />

      <TextView
        android:id="@+id/largeLastMatchLine"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@android:color/white"
        android:textSize="12sp"
        android:textStyle="bold" />

      <TextView
        android:id="@+id/largeLastMatchResult"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="#FFF3D7"
        android:textSize="13sp"
        android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_marginStart="4dp"
      android:layout_weight="1"
      android:background="@drawable/bg_widget_section"
      android:orientation="vertical"
      android:padding="10dp">

      <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/widget_next_match"
        android:textColor="#FFF3D7"
        android:textSize="10sp"
        android:textStyle="bold" />

      <TextView
        android:id="@+id/largeNextMatchDateTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@android:color/white"
        android:textSize="12sp"
        android:textStyle="bold" />

      <TextView
        android:id="@+id/largeNextMatchVenue"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="3dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="#CCFFFFFF"
        android:textSize="11sp" />

      <TextView
        android:id="@+id/largeNextMatchLine"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@android:color/white"
        android:textSize="12sp"
        android:textStyle="bold" />
    </LinearLayout>
  </LinearLayout>

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp"
    android:background="@drawable/bg_widget_section"
    android:orientation="vertical"
    android:padding="10dp">

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:gravity="center_vertical"
      android:orientation="horizontal">

      <TextView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="@string/widget_standing_label"
        android:textColor="#FFF3D7"
        android:textSize="10sp"
        android:textStyle="bold" />

      <TextView
        android:id="@+id/largeStandingWindow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="8dp"
        android:textColor="#CCFFFFFF"
        android:textSize="9sp" />

      <TextView
        android:id="@+id/largeStandingUpAction"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_widget_action"
        android:paddingLeft="7dp"
        android:paddingTop="3dp"
        android:paddingRight="7dp"
        android:paddingBottom="3dp"
        android:text="@string/widget_standing_up"
        android:textColor="@android:color/white"
        android:textSize="9sp"
        android:textStyle="bold" />

      <TextView
        android:id="@+id/largeStandingDownAction"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="4dp"
        android:background="@drawable/bg_widget_action"
        android:paddingLeft="7dp"
        android:paddingTop="3dp"
        android:paddingRight="7dp"
        android:paddingBottom="3dp"
        android:text="@string/widget_standing_down"
        android:textColor="@android:color/white"
        android:textSize="9sp"
        android:textStyle="bold" />
    </LinearLayout>

    <TextView
      android:id="@+id/largeStandingRow1"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="6dp"
      android:padding="6dp"
      android:textColor="#E6FFFFFF"
      android:textSize="10sp" />

    <TextView
      android:id="@+id/largeStandingRow2"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="4dp"
      android:padding="6dp"
      android:textColor="#E6FFFFFF"
      android:textSize="10sp" />

    <TextView
      android:id="@+id/largeStandingRow3"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="4dp"
      android:padding="6dp"
      android:textColor="#E6FFFFFF"
      android:textSize="10sp" />

    <TextView
      android:id="@+id/largeStandingRow4"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="4dp"
      android:padding="6dp"
      android:textColor="#E6FFFFFF"
      android:textSize="10sp" />

    <TextView
      android:id="@+id/largeStandingLastHint"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="6dp"
      android:ellipsize="end"
      android:maxLines="1"
      android:textColor="#CCFFFFFF"
      android:textSize="9sp" />

  </LinearLayout>

  <TextView
    android:id="@+id/widgetFooter"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="6dp"
    android:ellipsize="end"
    android:maxLines="1"
    android:textColor="#CCFFFFFF"
    android:textSize="10sp" />
</LinearLayout>
